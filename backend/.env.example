# 阿里云 OSS 配置
# OSS Endpoint (地域节点)
APP_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS Bucket 名称
APP_OSS_BUCKET=your-bucket-name
# OSS AccessKey ID
APP_OSS_ACCESS_KEY_ID=your-access-key-id
# OSS AccessKey Secret
APP_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# 是否启用 OSS 模拟模式 (true=本地存储, false=真实OSS)
APP_OSS_SIMULATE=false
# OSS 自定义域名前缀 (可选)
APP_OSS_URL_PREFIX=

# Coze API 配置
# Coze API 基础URL
COZE_BASE_URL=https://api.coze.cn
# Coze API Key
COZE_API_KEY=your-coze-api-key
# 是否启用 Coze 模拟模式
COZE_SIMULATE=false
# Mihe Key - 用于工作流执行时自动填充（如果工作流需要）
COZE_MIHE_KEY=your-mihe-key-here
