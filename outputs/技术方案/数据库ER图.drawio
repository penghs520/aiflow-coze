        <mxCell id="table_users" value="&lt;b&gt;users 用户表&lt;/b&gt;&lt;br&gt;id: BIGINT PK&lt;br&gt;phone: VARCHAR(20) UNIQUE&lt;br&gt;nickname: VARCHAR(50)&lt;br&gt;avatar_url: VARCHAR(500)&lt;br&gt;points_balance: BIGINT&lt;br&gt;status: TINYINT&lt;br&gt;last_login_at: DATETIME&lt;br&gt;created_at: DATETIME&lt;br&gt;updated_at: DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;" parent="1" vertex="1">
